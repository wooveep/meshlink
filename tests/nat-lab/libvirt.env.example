MESHLINK_BASE_IMAGE=/var/lib/libvirt/images/ubuntu-22.04-server-cloudimg-amd64.img
MESHLINK_LAB_TOPOLOGY=flat
MESHLINK_LIBVIRT_NETWORK=default
MESHLINK_UPSTREAM_NETWORK=default
MESHLINK_LIBVIRT_POOL=default
MESHLINK_OS_VARIANT=ubuntu22.04
MESHLINK_SSH_USER=meshlink
# MESHLINK_SSH_PUBLIC_KEY_FILE=/home/you/.ssh/id_ed25519.pub
# MESHLINK_SSH_PUBLIC_KEY="ssh-ed25519 AAAA..."

# Optional upstream static IP overrides. Leave unset to auto-derive from the
# active libvirt network, which avoids assuming a fixed 192.168.122.0/24 subnet.
# MESHLINK_MGMT_IP=192.168.123.201
# MESHLINK_CLIENT_A_IP=192.168.123.202
# MESHLINK_CLIENT_B_IP=192.168.123.203
# MESHLINK_GATEWAY=192.168.123.1
MESHLINK_MANAGEMENT_PORT=33073
MESHLINK_SYNC_INTERVAL=1s
# MESHLINK_CLIENT_A_WG_PORT=51820
# MESHLINK_CLIENT_B_WG_PORT=51821

# Dual NAT topology overrides for primary Phase 05 and Phase 06 validation.
# MESHLINK_LAB_TOPOLOGY=dual-nat
# MESHLINK_NAT_A_NETWORK_NAME=meshlink-nat-a-lan
# MESHLINK_NAT_B_NETWORK_NAME=meshlink-nat-b-lan
# MESHLINK_NAT_A_BRIDGE_NAME=mlnata0
# MESHLINK_NAT_B_BRIDGE_NAME=mlnatb0
# MESHLINK_NAT_A_WAN_IP=192.168.122.211
# MESHLINK_NAT_A_LAN_IP=10.10.1.1
# MESHLINK_NAT_B_WAN_IP=192.168.122.221
# MESHLINK_NAT_B_LAN_IP=10.10.2.1
# MESHLINK_CLIENT_A_IP=10.10.1.10
# MESHLINK_CLIENT_B_IP=10.10.2.10
# MESHLINK_NAT_A_LAN_CIDR=10.10.1.0/24
# MESHLINK_NAT_B_LAN_CIDR=10.10.2.0/24
# MESHLINK_NAT_A_LAN_HOST_IP=10.10.1.254
# MESHLINK_NAT_B_LAN_HOST_IP=10.10.2.254
