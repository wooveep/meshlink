MESHLINK_WINDOWS_VM_NAME=meshlink-win-a
MESHLINK_WINDOWS_OS_VARIANT=win11
MESHLINK_WINDOWS_MEMORY_MB=4096
MESHLINK_WINDOWS_VCPUS=4
MESHLINK_WINDOWS_DISK_GB=64
MESHLINK_WINDOWS_ATTACH_NETWORK=nat-a-lan
MESHLINK_WINDOWS_STATIC_IP=10.10.1.20
MESHLINK_WINDOWS_PREFIX=24
MESHLINK_WINDOWS_GATEWAY=10.10.1.1
MESHLINK_WINDOWS_DNS_1=1.1.1.1
MESHLINK_WINDOWS_DNS_2=8.8.8.8
MESHLINK_WINDOWS_WG_PORT=51820

# Required: Windows install media visible to libvirt host.
# MESHLINK_WINDOWS_ISO=/var/lib/libvirt/images/Win11_24H2_Chinese_Simplified_x64.iso

# Optional: import from an existing Windows qcow2 image instead of reinstalling.
# When this is set, MESHLINK_WINDOWS_ISO is not required.
# MESHLINK_WINDOWS_BASE_DISK=/var/lib/libvirt/images/win10.qcow2
# MESHLINK_WINDOWS_CLONE_MODE=backing
# Use `copy` if you want a fully independent disk clone.
# MESHLINK_WINDOWS_CLONE_MODE=copy

# Optional: attach a MeshLink package zip as a read-only ISO.
# MESHLINK_WINDOWS_PACKAGE=/home/you/code/meshlink/dist/windows/x86_64-pc-windows-gnu/meshlink-client_0.1.0_x86_64-pc-windows-gnu.zip
